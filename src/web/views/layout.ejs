<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>RubberForm Prospecting Engine</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter+Tight:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500;600&family=Oswald:wght@300;400;500;600;700&family=Yellowtail&display=swap" rel="stylesheet">
  <link href="/vendor/bootstrap/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <script>
    (function () {
      try {
        var saved = localStorage.getItem('rf-theme');
        if (saved === 'light' || saved === 'dark') {
          document.documentElement.setAttribute('data-theme', saved);
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <nav class="navbar navbar-expand-lg" style="background: var(--bg-deep); border-bottom: 1px solid var(--rule);">
    <div class="container-fluid">
      <a class="navbar-brand rf-logo" href="/" style="flex-direction: row; gap: 12px; align-items: center;">
        <span class="wordmark" style="font-size: 32px;">RFRP</span>
        <span class="subtitle" style="margin-top: 0;">Prospecting</span>
      </a>
      <div class="navbar-nav me-auto">
        <a class="nav-link sidebar-link" href="/" style="border-left:none;"><i class="bi bi-speedometer2"></i> Dashboard</a>
        <a class="nav-link sidebar-link" href="/review" style="border-left:none;"><i class="bi bi-check2-square"></i> Review</a>
        <a class="nav-link sidebar-link" href="/heatmap" style="border-left:none;"><i class="bi bi-geo-alt"></i> Heat Map</a>
        <a class="nav-link sidebar-link" href="/salesmap" style="border-left:none;"><i class="bi bi-pin-map"></i> Sales Map</a>
        <a class="nav-link sidebar-link" href="/reports" style="border-left:none;"><i class="bi bi-bar-chart"></i> Reports</a>
      </div>
      <div class="navbar-nav">
        <% if (typeof user !== 'undefined' && user) { %>
          <span class="nav-link"><i class="bi bi-person-circle"></i> <%= user.name %></span>
          <% if (MS365_ENABLED) { %><a class="nav-link" href="/logout">Logout</a><% } %>
        <% } %>
      </div>
    </div>
  </nav>
  <div class="container-fluid mt-3">
    <%- body %>
  </div>
  <script src="/vendor/bootstrap/bootstrap.bundle.min.js"></script>
  <% if (typeof scripts !== 'undefined') { %><%- scripts %><% } %>
</body>
</html>
