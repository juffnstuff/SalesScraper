<% title = 'Contact Lists' %>
<%- include('header') %>

<div class="row mb-3 align-items-center">
  <div class="col">
    <h3 class="mb-1"><i class="bi bi-collection text-primary"></i> Contact Lists</h3>
    <p class="text-muted mb-0">Build campaign lists from Apollo results, then push or export.</p>
  </div>
  <div class="col-auto">
    <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newListModal">
      <i class="bi bi-plus-lg"></i> New list
    </button>
  </div>
</div>

<div class="row">
  <!-- Left: list of lists -->
  <div class="col-md-4">
    <div class="card">
      <div class="card-header bg-white"><h6 class="mb-0">All lists</h6></div>
      <div id="listsIndex" class="list-group list-group-flush">
        <div class="text-center text-muted py-4"><div class="spinner-border spinner-border-sm"></div></div>
      </div>
    </div>
  </div>

  <!-- Right: selected list members -->
  <div class="col-md-8">
    <div id="listDetail">
      <div class="card">
        <div class="card-body text-center text-muted py-5">
          <i class="bi bi-arrow-left"></i> Select a list to view its contacts.
        </div>
      </div>
    </div>
  </div>
</div>

<!-- New list modal -->
<div class="modal fade" id="newListModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <form id="newListForm">
        <div class="modal-header">
          <h5 class="modal-title">Create a new list</h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
        </div>
        <div class="modal-body">
          <div class="mb-3">
            <label class="form-label">Name</label>
            <input type="text" class="form-control" id="newListName" required maxlength="120" placeholder="e.g. Q2 Parking Lot push">
          </div>
          <div class="mb-3">
            <label class="form-label">Description <small class="text-muted">(optional)</small></label>
            <textarea class="form-control" id="newListDescription" rows="2" maxlength="400"></textarea>
          </div>
          <div id="newListError" class="text-danger small d-none"></div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
          <button type="submit" class="btn btn-primary">Create</button>
        </div>
      </form>
    </div>
  </div>
</div>

<script src="/js/lists.js"></script>

<%- include('footer') %>
