<% title = rep.name + ' — Prospects' %>
<%- include('header') %>

<div class="row mb-3">
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item active"><%= rep.name %></li>
      </ol>
    </nav>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Rep Info -->
  <div class="col-md-3">
    <div class="card h-100">
      <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-person"></i> <%= rep.name %></h5>
      </div>
      <div class="card-body">
        <p class="mb-1"><strong>Title:</strong> <%= rep.title %></p>
        <p class="mb-1"><strong>Territory:</strong> <%= rep.territory %></p>
        <p class="mb-1"><strong>Email:</strong> <%= rep.email %></p>
        <% if (rep.verticals && rep.verticals.length > 0) { %>
          <p class="mb-1"><strong>Verticals:</strong></p>
          <% for (const v of rep.verticals) { %>
            <span class="badge bg-primary me-1"><%= v %></span>
          <% } %>
        <% } %>
        <hr>
        <% if (icp) { %>
          <p class="mb-1"><strong>Deal Sweet Spot:</strong> $<%= (icp.dealSizeRange?.sweet_spot || 0).toLocaleString() %></p>
          <p class="mb-1"><strong>Geographies:</strong> <%= (icp.geographies || []).slice(0, 8).join(', ') %></p>
          <p class="mb-2"><strong>Top Products:</strong></p>
          <% (icp.productAffinities || []).slice(0, 6).forEach(p => { %>
            <span class="product-tag"><%= p %></span>
          <% }); %>
          <div class="mt-3">
            <a href="/icp/<%= rep.id %>" class="btn btn-sm btn-outline-secondary">View Full ICP</a>
          </div>
        <% } else { %>
          <div class="alert alert-warning">No ICP generated yet.</div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Projects Panel -->
  <div class="col-md-9">
    <div class="card">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-building"></i> Projects in Your Verticals</h5>
        <span class="text-muted small" id="projectCount"></span>
      </div>
      <div class="card-body p-0">
        <div id="loadingIndicator" class="text-center py-4">
          <span class="spinner-border spinner-border-sm"></span> Loading projects...
        </div>
        <div id="projectList" style="display:none;"></div>
        <div id="emptyState" style="display:none;" class="text-center text-muted py-5">
          <i class="bi bi-inbox" style="font-size: 2.5rem; opacity: 0.3;"></i>
          <p class="mt-2">No projects found for your verticals.<br>Run a <a href="/heatmap">Heat Map scan</a> to discover projects.</p>
        </div>
      </div>
    </div>

    <!-- Project Detail / Contacts Panel -->
    <div class="card mt-3" id="detailCard" style="display:none;">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h6 class="mb-0" id="detailTitle"><i class="bi bi-building"></i> Project Details</h6>
        <button class="btn btn-sm btn-outline-secondary" onclick="closeDetail()"><i class="bi bi-x-lg"></i></button>
      </div>
      <div class="card-body" id="detailContent"></div>
    </div>
  </div>
</div>

<script>
  const REP_ID = '<%= rep.id %>';
  const REPS = <%- JSON.stringify(reps.map(r => ({ id: r.id, name: r.name, verticals: r.verticals || [] }))) %>;
</script>
<script src="/js/search.js"></script>
<%- include('footer') %>
