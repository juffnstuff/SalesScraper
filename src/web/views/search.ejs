<% title = rep.name + ' — Search' %>
<%- include('header') %>

<div class="row mb-3">
  <div class="col">
    <nav aria-label="breadcrumb">
      <ol class="breadcrumb">
        <li class="breadcrumb-item"><a href="/">Dashboard</a></li>
        <li class="breadcrumb-item active"><%= rep.name %></li>
      </ol>
    </nav>
  </div>
</div>

<div class="row g-3 mb-4">
  <!-- Rep Info -->
  <div class="col-md-4">
    <div class="card h-100">
      <div class="card-header bg-white">
        <h5 class="mb-0"><i class="bi bi-person"></i> <%= rep.name %></h5>
      </div>
      <div class="card-body">
        <p class="mb-1"><strong>Title:</strong> <%= rep.title %></p>
        <p class="mb-1"><strong>Territory:</strong> <%= rep.territory %></p>
        <p class="mb-1"><strong>Email:</strong> <%= rep.email %></p>
        <% if (rep.hubspotAssignTo) { %>
          <p class="mb-1"><span class="badge bg-info">Prospects assigned to <%= rep.hubspotAssignTo %></span></p>
        <% } %>
        <hr>
        <% if (icp) { %>
          <p class="mb-1"><strong>Deal Sweet Spot:</strong> $<%= (icp.dealSizeRange?.sweet_spot || 0).toLocaleString() %></p>
          <p class="mb-1"><strong>Geographies:</strong> <%= (icp.geographies || []).join(', ') %></p>
          <p class="mb-2"><strong>Top Products:</strong></p>
          <% (icp.productAffinities || []).forEach(p => { %>
            <span class="product-tag"><%= p %></span>
          <% }); %>
          <div class="mt-3">
            <a href="/icp/<%= rep.id %>" class="btn btn-sm btn-outline-secondary">View Full ICP</a>
          </div>
        <% } else { %>
          <div class="alert alert-warning">No ICP generated for this rep yet.</div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Search Panel -->
  <div class="col-md-8">
    <div class="card">
      <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-search"></i> Prospect Search</h5>
        <button id="searchBtn" class="btn btn-primary" onclick="runSearch('<%= rep.id %>')">
          <span class="search-text"><i class="bi bi-play-fill"></i> Run Search</span>
          <span class="search-spinner"><span class="spinner-border spinner-border-sm"></span> Searching...</span>
        </button>
      </div>
      <div class="card-body">
        <div id="searchStatus" class="text-muted mb-3">
          Click "Run Search" to find prospects matching <%= rep.name %>'s ICP across SAM.gov, State DOTs, BidNet, and the open web.
        </div>

        <!-- Results summary -->
        <div id="resultsSummary" style="display: none;" class="row g-2 mb-3">
          <div class="col-3"><div class="card bg-light text-center p-2"><div class="stat-value" id="statTotal">0</div><div class="stat-label">Found</div></div></div>
          <div class="col-3"><div class="card bg-light text-center p-2"><div class="stat-value" id="statQualified">0</div><div class="stat-label">Qualified</div></div></div>
          <div class="col-3"><div class="card bg-light text-center p-2"><div class="stat-value text-success" id="statHigh">0</div><div class="stat-label">Score 85+</div></div></div>
          <div class="col-3"><div class="card bg-light text-center p-2"><div class="stat-value text-warning" id="statMid">0</div><div class="stat-label">Score 60-84</div></div></div>
        </div>

        <!-- Results table -->
        <div id="resultsArea"></div>
      </div>
    </div>
  </div>
</div>

<script src="/js/search.js"></script>
<%- include('footer') %>
