<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — ' : '' %>RubberForm Prospecting Engine</title>
  <link href="/vendor/bootstrap/bootstrap.min.css" rel="stylesheet">
  <link href="/vendor/bootstrap-icons/bootstrap-icons.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
    <div class="container-fluid">
      <a class="navbar-brand" href="/">
        <i class="bi bi-bullseye"></i> RubberForm Prospecting
      </a>
      <div class="navbar-nav me-auto">
        <a class="nav-link" href="/"><i class="bi bi-speedometer2"></i> Dashboard</a>
        <a class="nav-link" href="/review"><i class="bi bi-check2-square"></i> Review</a>
        <a class="nav-link" href="/heatmap"><i class="bi bi-geo-alt"></i> Heat Map</a>
        <a class="nav-link" href="/salesmap"><i class="bi bi-pin-map"></i> Sales Map</a>
        <a class="nav-link" href="/reports"><i class="bi bi-bar-chart"></i> Reports</a>
      </div>
      <div class="navbar-nav">
        <% if (typeof user !== 'undefined' && user) { %>
          <span class="nav-link text-light">
            <i class="bi bi-person-circle"></i> <%= user.name %>
            <% if (user.role) { %>
              <span class="badge bg-<%= user.role === 'admin' ? 'warning text-dark' : 'info' %> ms-1" style="font-size:0.65rem;"><%= user.role === 'admin' ? 'Admin' : 'Rep' %></span>
            <% } %>
          </span>
          <a class="nav-link" href="/change-password"><i class="bi bi-key"></i></a>
          <a class="nav-link" href="/logout"><i class="bi bi-box-arrow-right"></i> Logout</a>
        <% } %>
      </div>
    </div>
  </nav>
  <div class="container-fluid mt-3">
