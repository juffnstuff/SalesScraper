<% title = 'Heat Map' %>
<%- include('header') %>

<!-- Leaflet CSS -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.css" />
<link rel="stylesheet" href="https://unpkg.com/leaflet.markercluster@1.5.3/dist/MarkerCluster.Default.css" />

<div class="row mb-3">
  <div class="col">
    <h3><i class="bi bi-geo-alt-fill text-danger"></i> US Construction Activity Heat Map</h3>
    <p class="text-muted mb-0">Construction projects mapped by product lifecycle stage. Data from all prospecting searches.</p>
  </div>
</div>

<!-- Controls -->
<div class="row mb-3">
  <div class="col-md-8">
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <span class="fw-bold small text-muted">FILTER:</span>
      <button class="btn btn-sm stage-toggle active" id="toggleConstruction" data-stage="construction" style="background: #ea580c; color: white; border: 2px solid #ea580c;">
        <i class="bi bi-building"></i> Construction
      </button>
      <button class="btn btn-sm stage-toggle active" id="toggleParking" data-stage="parking_industrial" style="background: #2563eb; color: white; border: 2px solid #2563eb;">
        <i class="bi bi-p-square"></i> Parking / Industrial
      </button>
      <button class="btn btn-sm stage-toggle active" id="toggleMunicipal" data-stage="municipal" style="background: #16a34a; color: white; border: 2px solid #16a34a;">
        <i class="bi bi-sign-stop"></i> Municipal / Traffic Calming
      </button>
      <span class="mx-2 text-muted">|</span>
      <select class="form-select form-select-sm" id="timeRange" style="width: auto;">
        <option value="0">All Time</option>
        <option value="7">Last 7 Days</option>
        <option value="30" selected>Last 30 Days</option>
        <option value="90">Last 90 Days</option>
      </select>
    </div>
  </div>
  <div class="col-md-4 text-end">
    <button class="btn btn-sm btn-outline-danger" id="scanBtn" onclick="scanForNews()">
      <span class="scan-text"><i class="bi bi-search"></i> Scan for Fresh News</span>
      <span class="scan-spinner"><span class="spinner-border spinner-border-sm"></span> Scanning... (2-3 min)</span>
    </button>
  </div>
</div>

<!-- Map + Sidebar -->
<div class="row">
  <div class="col-lg-8">
    <div class="card">
      <div id="heatmap"></div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card heatmap-sidebar" id="sidebarCard">
      <div class="card-header bg-white">
        <h6 class="mb-0" id="sidebarTitle"><i class="bi bi-info-circle"></i> Click a marker for details</h6>
      </div>
      <div class="card-body p-0" id="sidebarContent">
        <div class="text-center text-muted py-5">
          <i class="bi bi-geo-alt" style="font-size: 3rem; opacity: 0.3;"></i>
          <p class="mt-2">Select a project marker on the map to view details.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Summary Stats -->
<div class="row g-3 mt-2 mb-3">
  <div class="col-md-3">
    <div class="card text-center">
      <div class="card-body py-2">
        <div class="stat-value" id="statTotal">0</div>
        <div class="stat-label">Total Projects</div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-center">
      <div class="card-body py-2">
        <div class="stat-value stage-construction" id="statConstruction">0</div>
        <div class="stat-label">Construction Starts</div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-center">
      <div class="card-body py-2">
        <div class="stat-value stage-parking" id="statParking">0</div>
        <div class="stat-label">Parking / Industrial</div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="card text-center">
      <div class="card-body py-2">
        <div class="stat-value stage-municipal" id="statMunicipal">0</div>
        <div class="stat-label">Municipal / Traffic Calming</div>
      </div>
    </div>
  </div>
</div>

<!-- Legend -->
<div class="row mb-4">
  <div class="col">
    <div class="card">
      <div class="card-body py-2 d-flex gap-4 flex-wrap align-items-center">
        <span class="fw-bold small text-muted">LEGEND:</span>
        <div class="legend-item">
          <span class="legend-dot" style="background: #ea580c;"></span>
          <small><strong>Construction Starts</strong> — Data centers, highways, warehouses, campuses</small>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background: #2563eb;"></span>
          <small><strong>Parking / Industrial</strong> — Parking lots, commercial, retail, paving</small>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background: #16a34a;"></span>
          <small><strong>Municipal / Traffic Calming</strong> — Vision Zero, school zones, safe streets</small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Leaflet JS -->
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script src="https://unpkg.com/leaflet.markercluster@1.5.3/dist/leaflet.markercluster.js"></script>
<script src="/js/heatmap.js"></script>

<%- include('footer') %>
