<% title = 'Sales Map' %>
<%- include('header') %>

<!-- Leaflet CSS (local) -->
<link rel="stylesheet" href="/vendor/leaflet/leaflet.css" />
<link rel="stylesheet" href="/vendor/leaflet.markercluster/MarkerCluster.css" />
<link rel="stylesheet" href="/vendor/leaflet.markercluster/MarkerCluster.Default.css" />

<div class="row mb-3">
  <div class="col">
    <h3><i class="bi bi-pin-map-fill text-primary"></i> Sales & Quote Activity Map</h3>
    <p class="text-muted mb-0">NetSuite sales orders and quotes mapped by shipping address.</p>
  </div>
</div>

<!-- Controls -->
<div class="row mb-3">
  <div class="col-md-9">
    <div class="d-flex gap-2 align-items-center flex-wrap">
      <span class="fw-bold small text-muted">LAYERS:</span>
      <button class="btn btn-sm stage-toggle active" data-stage="quoted" style="background: #16a34a; color: white; border: 2px solid #16a34a;">
        <i class="bi bi-file-earmark-check"></i> Quote &rarr; Sale
      </button>
      <button class="btn btn-sm stage-toggle active" data-stage="direct" style="background: #2563eb; color: white; border: 2px solid #2563eb;">
        <i class="bi bi-cart-check"></i> Direct Sale
      </button>
      <button class="btn btn-sm stage-toggle active" data-stage="open" style="background: #ea580c; color: white; border: 2px solid #ea580c;">
        <i class="bi bi-file-earmark-text"></i> Open Quotes
      </button>
      <button class="btn btn-sm stage-toggle active" data-stage="lost" style="background: #dc2626; color: white; border: 2px solid #dc2626;">
        <i class="bi bi-x-circle"></i> Lost Quotes
      </button>
      <span class="mx-2 text-muted">|</span>
      <select class="form-select form-select-sm" id="repFilter" style="width: auto;">
        <option value="">All Reps</option>
        <% for (const rep of reps) { %>
          <option value="<%= rep.id %>"><%= rep.name %></option>
        <% } %>
      </select>
      <span class="mx-2 text-muted">|</span>
      <span class="fw-bold small text-muted">YEARS:</span>
      <div class="dropdown d-inline-block">
        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" id="yearDropdownBtn" data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
          All Years
        </button>
        <ul class="dropdown-menu" id="yearDropdownMenu" style="min-width: 140px;">
        </ul>
      </div>
    </div>
  </div>
  <div class="col-md-3 text-end">
    <button class="btn btn-sm btn-outline-primary" id="syncBtn" onclick="triggerNetSuiteSync()" title="Pull latest changes from NetSuite">
      <i class="bi bi-arrow-repeat" id="syncIcon"></i> Sync NetSuite
    </button>
    <div class="mt-1">
      <span class="text-muted small" id="loadingIndicator" style="display:none;">
        <span class="spinner-border spinner-border-sm"></span> Loading...
      </span>
      <span class="text-muted small" id="syncStatus"></span>
    </div>
  </div>
</div>

<!-- Map + Sidebar -->
<div class="row">
  <div class="col-lg-8">
    <div class="card">
      <div id="salesmap"></div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card salesmap-sidebar" id="sidebarCard">
      <div class="card-header bg-white">
        <h6 class="mb-0" id="sidebarTitle"><i class="bi bi-info-circle"></i> Click a marker for details</h6>
      </div>
      <div class="card-body p-0" id="sidebarContent">
        <div class="text-center text-muted py-5">
          <i class="bi bi-pin-map" style="font-size: 3rem; opacity: 0.3;"></i>
          <p class="mt-2">Select a transaction marker on the map to view details.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Summary Stats -->
<div class="row g-3 mt-2 mb-3">
  <div class="col">
    <div class="card text-center stat-tile" style="cursor:pointer;" onclick="showTransactionList('quoted')">
      <div class="card-body py-2">
        <div class="stat-value text-success" id="statQuotedRevenue">$0</div>
        <div class="stat-label">Quote &rarr; Sale</div>
        <div class="small text-muted"><span id="statQuoted">0</span> orders</div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card text-center stat-tile" style="cursor:pointer;" onclick="showTransactionList('direct')">
      <div class="card-body py-2">
        <div class="stat-value" style="color:#2563eb;" id="statDirectRevenue">$0</div>
        <div class="stat-label">Direct Sale</div>
        <div class="small text-muted"><span id="statDirect">0</span> orders</div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card text-center stat-tile" style="cursor:pointer;" onclick="showTransactionList('open')">
      <div class="card-body py-2">
        <div class="stat-value layer-open" id="statOpenValue">$0</div>
        <div class="stat-label">Open Quotes</div>
        <div class="small text-muted"><span id="statOpen">0</span> quotes</div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card text-center stat-tile" style="cursor:pointer;" onclick="showTransactionList('lost')">
      <div class="card-body py-2">
        <div class="stat-value layer-lost" id="statLostValue">$0</div>
        <div class="stat-label">Lost</div>
        <div class="small text-muted"><span id="statLost">0</span> quotes</div>
      </div>
    </div>
  </div>
  <div class="col">
    <div class="card text-center stat-tile" style="cursor:pointer;" onclick="showTransactionList('all')">
      <div class="card-body py-2">
        <div class="stat-value" id="statTotal">0</div>
        <div class="stat-label">Total</div>
        <div class="small text-muted" id="statDirectPct">--% direct</div>
      </div>
    </div>
  </div>
</div>

<!-- Legend -->
<div class="row mb-4">
  <div class="col">
    <div class="card">
      <div class="card-body py-2 d-flex gap-4 flex-wrap align-items-center">
        <span class="fw-bold small text-muted">LEGEND:</span>
        <div class="legend-item">
          <span class="legend-dot" style="background: #16a34a;"></span>
          <small><strong>Quote &rarr; Sale</strong> &mdash; Sales orders that started as a quote</small>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background: #2563eb;"></span>
          <small><strong>Direct Sale</strong> &mdash; Sales orders with no prior quote</small>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background: #ea580c;"></span>
          <small><strong>Open Quotes</strong> &mdash; Active estimates pending decision</small>
        </div>
        <div class="legend-item">
          <span class="legend-dot" style="background: #dc2626;"></span>
          <small><strong>Lost Quotes</strong> &mdash; Expired, voided, or declined estimates</small>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Leaflet JS (local) -->
<script src="/vendor/leaflet/leaflet.js"></script>
<script src="/vendor/leaflet.markercluster/leaflet.markercluster.js"></script>
<script src="/js/salesmap.js"></script>

<%- include('footer') %>
