# Anthropic (for ICP synthesis and scoring)
ANTHROPIC_API_KEY=

# PostgreSQL (Railway provides this automatically)
DATABASE_URL=

# Microsoft 365 / Azure AD
# Used for both Outlook email access (via MCP) and web SSO ("Sign in with Microsoft 365").
# Setting MS365_TENANT_ID + MS365_CLIENT_ID enables the SSO button on /login.
#
# Azure AD app registration steps:
#   1. Azure Portal → App registrations → New registration
#   2. Supported account types: "Accounts in this organizational directory only"
#   3. Redirect URI: platform = Web, value = AUTH_REDIRECT_URI below (HTTPS in prod)
#   4. Authentication → Front-channel logout URL: https://<host>/login
#   5. API permissions → Microsoft Graph (delegated): openid, profile, email
#      → Grant admin consent
#   6. Certificates & secrets → New client secret → copy into MS365_CLIENT_SECRET
#   7. Overview tab supplies MS365_TENANT_ID (Directory ID) and MS365_CLIENT_ID (Application ID)
#
# Sign-in policy: only @rubberform.com accounts that already exist in
# config/users.json are admitted. Add the local row before the first MS365 login.
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=

# NetSuite (for SuiteQL queries via MCP)
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# HubSpot
HUBSPOT_ACCESS_TOKEN=

# Selling.com
SELLING_API_KEY=
SELLING_API_BASE_URL=https://api.selling.com/v1

# Web App
PORT=3000
SESSION_SECRET=change-this-to-a-random-string
# AUTH_REDIRECT_URI must match the Azure AD app's Redirect URI exactly.
# In production (NODE_ENV=production) this MUST be HTTPS or the server will refuse to start.
AUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Run Config
DEFAULT_ICP_LOOKBACK_DAYS=365
MIN_RELEVANCE_SCORE=60
MAX_CONTACTS_PER_PROJECT=3
DRY_RUN=false
