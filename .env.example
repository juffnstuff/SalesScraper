# Anthropic (for ICP synthesis and scoring)
ANTHROPIC_API_KEY=

# Microsoft 365 (for Outlook email access via MCP)
MS365_TENANT_ID=
MS365_CLIENT_ID=
MS365_CLIENT_SECRET=

# NetSuite (for SuiteQL queries via MCP)
NETSUITE_ACCOUNT_ID=
NETSUITE_CONSUMER_KEY=
NETSUITE_CONSUMER_SECRET=
NETSUITE_TOKEN_ID=
NETSUITE_TOKEN_SECRET=

# HubSpot
HUBSPOT_ACCESS_TOKEN=

# Selling.com
SELLING_API_KEY=
SELLING_API_BASE_URL=https://api.selling.com/v1

# Web App
PORT=3000
SESSION_SECRET=change-this-to-a-random-string
AUTH_REDIRECT_URI=http://localhost:3000/auth/callback

# Run Config
DEFAULT_ICP_LOOKBACK_DAYS=365
MIN_RELEVANCE_SCORE=60
MAX_CONTACTS_PER_PROJECT=3
DRY_RUN=false
